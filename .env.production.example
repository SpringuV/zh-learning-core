# Public base URL exposed by Nginx (must be HTTPS in production)
PUBLIC_BASE_URL=https://your-domain.com

# NextAuth secret (use a long random value)
NEXTAUTH_SECRET=replace_with_strong_random_secret

# PostgreSQL container settings
POSTGRES_DB=identity_hanzi
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
USERS_DB=users_hanzi

# Backend connection strings (must match postgres settings above)
AUTH_IDENTITY_DB_CONNECTION=Host=postgres;Port=5432;Database=identity_hanzi;Username=postgres;Password=postgres
USERS_DB_CONNECTION=Host=postgres;Port=5432;Database=users_hanzi;Username=postgres;Password=postgres
OUTBOX_DB_CONNECTION=Host=postgres;Port=5432;Database=identity_hanzi;Username=postgres;Password=postgres

# Optional tuning
OCR_TIMEOUT_SECONDS=120
